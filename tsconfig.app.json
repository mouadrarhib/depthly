{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Path aliases */
    "baseUrl": ".",
    "paths": {
      "@/*":            ["./src/*"],
      "@/components/*": ["./src/components/*"],
      "@/pages/*":      ["./src/pages/*"],
      "@/hooks/*":      ["./src/hooks/*"],
      "@/store/*":      ["./src/store/*"],
      "@/lib/*":        ["./src/lib/*"],
      "@/types/*":      ["./src/types/*"],
      "@/styles/*":     ["./src/styles/*"],
      "@/routes/*":     ["./src/routes/*"]
    },

    /* Strict mode — always on */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"]
}
