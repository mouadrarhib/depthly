# ── Supabase ────────────────────────────────────────────────────────────────
# Get these from: https://app.supabase.com → your project → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ── App ─────────────────────────────
────────────────────────────────────────
VITE_APP_NAME=Depthly
VITE_APP_URL=http://localhost:5173

# ── Stripe (optional) ────────────────────────────────────────────────────────
# NEVER put secret keys here — they are client-side visible.
# Secret keys go in Supabase Edge Function secrets and Vercel env vars only.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── Lemon Squeezy (Supabase Edge Function secrets) ───────────────────────────
# No VITE_ prefix — these are read by the create-checkout and
# lemonsqueezy-webhook Edge Functions only, never bundled into client code.
# The values below are TEST-MODE placeholders. Once the Lemon Squeezy store is
# approved and switched to live mode, swap these for the live-mode store ID,
# variant IDs, API key, and webhook signing secret before going live.
LEMONSQUEEZY_STORE_ID=your-test-mode-store-id
LEMONSQUEEZY_VARIANT_PRO_MONTHLY=your-test-mode-monthly-variant-id
LEMONSQUEEZY_VARIANT_PRO_YEARLY=your-test-mode-yearly-variant-id
LEMONSQUEEZY_VARIANT_LIFETIME=your-test-mode-lifetime-variant-id
LEMONSQUEEZY_API_KEY=your-test-mode-api-key
LEMONSQUEEZY_WEBHOOK_SECRET=your-webhook-signing-secret
